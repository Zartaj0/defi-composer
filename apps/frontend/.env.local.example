# Copy this to .env.local for local development

# Backend API (local dev)
NEXT_PUBLIC_API_URL=http://localhost:3001

# WalletConnect project ID (get one free at https://cloud.walletconnect.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=606c14e6417fd9a07477068b05e1d3a2

# ── Fork mode (uncomment to use local Anvil fork instead of live chains) ──────
# Run first: bash scripts/fork-dev.sh 0xYourWalletAddress
# Then uncomment the line below and restart the dev server.
# NEXT_PUBLIC_FORK_RPC_URL=http://127.0.0.1:8545
