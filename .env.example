# ============================================================
# DeFi Composer — Environment Variables
# Copy to .env.local and fill in your values
# ============================================================

# ── AI providers (set ONE — priority: OpenRouter → Gemini → Mistral → NVIDIA) ──
# OpenRouter: https://openrouter.ai/keys  (best free tier, wraps all models)
OPENROUTER_API_KEY=your_openrouter_key_here

# Google Gemini: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_key_here

# Mistral: https://console.mistral.ai/api-keys
MISTRAL_API_KEY=your_mistral_key_here

# NVIDIA NIM: https://build.nvidia.com
NVIDIA_API_KEY=your_nvidia_key_here

# RPC — Base
BASE_RPC_URL=https://mainnet.base.org
BASE_WSS_URL=wss://mainnet.base.org

# Tenderly (simulation)
TENDERLY_ACCESS_KEY=your_tenderly_key
TENDERLY_ACCOUNT=your_account
TENDERLY_PROJECT=defi-composer

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/defi_composer
REDIS_URL=redis://localhost:6379
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password

# Safe / ERC-4337
SAFE_API_URL=https://safe-transaction-base.safe.global

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
API_URL=http://localhost:3001
PORT=3001
NODE_ENV=development

# Auth (optional for MVP)
NEXTAUTH_SECRET=your_secret_here
NEXTAUTH_URL=http://localhost:3000
